{
  "cleanUrls": true,
  "trailingSlash": true,
  "rewrites": [
    { "source": "/", "destination": "/calchub/index.html" },
    { "source": "/uk", "destination": "/calchub/uk/index.html" },
    { "source": "/ru", "destination": "/calchub/ru/index.html" },
    { "source": "/uk/(.*)", "destination": "/calchub/uk/$1" },
    { "source": "/ru/(.*)", "destination": "/calchub/ru/$1" },
    { "source": "/(.*)", "destination": "/calchub/$1" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Cache-Control", "value": "public, max-age=3600" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}